{
  "name": "prts-mcp-ts",
  "version": "1.3.0",
  "description": "MCP Server for Arknights PRTS Wiki & game data (TypeScript / Streamable HTTP)",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "prts-mcp-ts": "./dist/server.js"
  },
  "files": [
    "dist/",
    "data/"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/3aKHP/prts-mcp.git",
    "directory": "ts"
  },
  "homepage": "https://github.com/3aKHP/prts-mcp",
  "bugs": "https://github.com/3aKHP/prts-mcp/issues",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "arknights",
    "prts",
    "prts-wiki",
    "game-data",
    "claude",
    "anthropic",
    "fanfiction",
    "ai-agent",
    "streamable-http"
  ],
  "volta": {
    "node": "24.14.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
