# Optional: provide a GitHub token to reduce anonymous API rate-limit risk
GITHUB_TOKEN=

# Optional: comma-separated ghproxy-style GitHub mirror prefixes.
# Example: GITHUB_MIRRORS=https://ghproxy.net
GITHUB_MIRRORS=

# Optional: override the default auto-sync game-data directory with your own local path.
# Setting this disables automatic GameData excel/levels sync. If the path is a full
# ArknightsGameData repo root, zh_CN/gamedata/levels is used directly; otherwise
# level combat data is expected in a sibling gamedata-levels directory.
GAMEDATA_PATH=

# Optional: override the default auto-synced story zip with your own zh_CN.zip.
STORYJSON_PATH=
